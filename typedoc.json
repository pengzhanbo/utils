{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["./src/index.ts"],
  "exclude": ["**/*.test.ts"],
  "router": "category",
  "out": "docs/dist",
  "cleanOutputDir": true,
  "json": "docs/dist/typedoc.json",
  "categoryOrder": [
    "Predicate",
    "Array",
    "Object",
    "String",
    "Promise",
    "Function",
    "Date",
    "Guard",
    "Math",
    "Types",
    "URL",
    "Util",
    "Error",
    "Event",
    "Clone",
    "*"
  ],
  "navigation": {
    "includeCategories": true
  },
  "navigationLinks": {
    "GitHub": "https://github.com/pengzhanbo/utils",
    "NPM": "https://www.npmjs.com/package/@pengzhanbo/utils",
    "NPMX.DEV": "https://npmx.dev/package/@pengzhanbo/utils",
    "JSR": "https://jsr.io/@pengzhanbo/utils",
    "@pengzhanbo": "https://pengzhanbo.cn"
  },
  "includeVersion": true,
  "readme": "none",
  "excludeInternal": true,
  "excludePrivate": true,
  "excludeProtected": true,
  "excludePrivateClassFields": true,
  "validation": {
    "invalidLink": true
  },
  "treatWarningsAsErrors": false,
  "emit": "docs",
  "pretty": true,
  "plugin": [
    "typedoc-github-theme",
    "typedoc-plugin-coverage",
    "typedoc-plugin-mdn-links",
    "typedoc-plugin-missing-exports"
  ],
  "customCss": "./docs/theme/custom.css"
}
