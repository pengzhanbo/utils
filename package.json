{
  "name": "@pengzhanbo/utils",
  "version": "3.5.0",
  "keywords": [
    "utils"
  ],
  "homepage": "https://github.com/pengzhanbo/utils",
  "bugs": "https://github.com/pengzhanbo/utils/issues",
  "license": "MIT",
  "author": "pengzhanbo <q942450674@outlook.com> (https://github.com/pengzhanbo)",
  "repository": {
    "type": "git",
    "url": "https://github.com/pengzhanbo/utils.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "lint": "oxlint . --type-check --type-aware",
    "format": "oxfmt .",
    "prepublishOnly": "pnpm run build",
    "test": "cross-env TZ=Etc/UTC vitest --coverage",
    "release:publish": "pnpm publish --provenance --access public",
    "release": "bumpp package.json jsr.json --commit \"build: publish v%s\" --push --tag --all",
    "prepare": "husky",
    "docs:dev": "typedoc --watch",
    "docs:build": "typedoc",
    "docs:preview": "http-server docs/dist"
  },
  "devDependencies": {
    "@pengzhanbo/tsconfig": "^2.4.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "bumpp": "^11.0.1",
    "cross-env": "^10.1.0",
    "http-server": "^14.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "oxfmt": "^0.46.0",
    "oxlint": "^1.61.0",
    "oxlint-tsgolint": "^0.21.1",
    "tsdown": "^0.21.9",
    "typedoc": "^0.28.19",
    "typedoc-github-theme": "^0.4.0",
    "typedoc-plugin-coverage": "^4.0.3",
    "typedoc-plugin-mdn-links": "^5.1.1",
    "typedoc-plugin-missing-exports": "^4.1.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{js,ts,mjs,cjs}": "pnpm run lint",
    "*": "oxfmt --no-error-on-unmatched-pattern",
    "*.{js,ts}": "vitest related --run"
  },
  "packageManager": "pnpm@10.33.0"
}
